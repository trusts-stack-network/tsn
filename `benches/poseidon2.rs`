use criterion::{black_box, criterion_group, criterion_main, Criterion};
use tsn::crypto::poseidon::PoseidonHash;

fn bench_poseidon2_hash(c: &mut Criterion) {
    let hasher = PoseidonHash::new();
    let data = vec![1u8; 32];
    
    c.bench_function("poseidon2_hash_32bytes", |b| {
        b.iter(|| {
            black_box(hasher.hash(&data))
        })
    });
}

criterion_group!(benches, bench_poseidon2_hash);
criterion_main!(benches);