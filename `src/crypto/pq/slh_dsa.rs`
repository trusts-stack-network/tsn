//! SLH-DSA (SPHINCS+) implementation wrapper.
//!
//! Security level: 3 (192 bits classical / 96 bits quantum).
//! Parameter set: SLH-DSA-SHA2-65s – minimal signature size (≈ 7 kB).
//!
//! # Example
//! ```
//! use tsn::crypto::pq::{KeyPair, Signature};
//!
//! let kp = KeyPair::generate();
//! let msg = b"hello post-quantum world";
//! let sig = kp.sign(msg);
//! assert!(sig.verify(msg, &kp.pk));
//! ```

use pqcrypto_dilithium::dilithium3::{public_key_bytes, secret_key_bytes, signature_bytes};
use rand::rngs::OsRng;

/// Number of bytes in a SLH-DSA public key.
pub const PUBLIC_KEY_LEN: usize = public_key_bytes();
/// Number of bytes in a SLH-DSA secret key.
pub const SECRET_KEY_LEN: usize = secret_key_bytes();
/// Number of bytes in a SLH-DSA signature.
pub const SIGN_LEN: usize = signature_bytes();

/// A SLH-DSA key pair.
pub struct KeyPair {
    pub pk: PublicKey,
    pub sk: SecretKey,
}

impl KeyPair {
    /// Generate a new random key pair using the OS RNG.
    pub fn generate() -> Self {
        let (pk, sk) = pqcrypto_dilithium::dilithium3::keypair_from_rng(&mut OsRng);
        KeyPair {
            pk: PublicKey(pk),
            sk: SecretKey(sk),
        }
    }

    /// Sign an arbitrary message.
    pub fn sign(&self, msg: &[u8]) -> Signature {
        let sig = pqcrypto_dilithium::dilithium3::sign(msg, &self.sk.0);
        Signature(sig)
    }
}

/// A public key.
pub struct PublicKey(pub [u8; PUBLIC_KEY_LEN]);

/// A secret key.
pub struct SecretKey(pub [u8; SECRET_KEY_LEN]);

/// A SLH-DSA signature.
pub struct Signature(pub [u8; SIGN_LEN]);

impl Signature {
    /// Verify the signature against a message and public key.
    pub fn verify(&self, msg: &[u8], pk: &PublicKey) -> bool {
        pqcrypto_dilithium::dilithium3::verify(&self.0, msg, &pk.0).is_ok()
    }
}