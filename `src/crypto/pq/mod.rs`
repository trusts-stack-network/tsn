//! Post-quantum cryptographic primitives used by Trust Stack Network.
//!
//! This module exposes only the minimal API surface required by the rest of
//! the node.  Internally it relies on `pqcrypto` which provides the reference
//! implementation of SLH-DSA (FIPS 204) – the only post-quantum signature
//! algorithm currently supported by TSN.
//!
//! References:
//!   - NIST FIPS 204 (draft) – Stateless Hash-Based Digital Signature Standard
//!   - pqcrypto: <https://docs.rs/pqcrypto>

pub mod slh_dsa;
pub use slh_dsa::{KeyPair, Signature, PUBLIC_KEY_LEN, SECRET_KEY_LEN, SIGN_LEN};