use std::collections::HashMap;

#[derive(Debug, Clone)]
pub struct State {
    pub balances: HashMap<String, u64>,
    pub nonce: u64,
}

impl State {
    pub fn new() -> Self {
        Self {
            balances: HashMap::new(),
            nonce: 0,
        }
    }
}

#[derive(Debug, Clone)]
pub struct ShieldedState {
    pub commitment_tree_root: [u8; 32],
    pub nullifiers: Vec<[u8; 32]>,
    pub notes: Vec<crate::crypto::note::EncryptedNote>,
}

impl ShieldedState {
    pub fn new() -> Self {
        Self {
            commitment_tree_root: [0u8; 32],
            nullifiers: Vec::new(),
            notes: Vec::new(),
        }
    }
}

#[derive(Debug, Clone)]
pub struct Account {
    pub address: String,
    pub balance: u64,
    pub nonce: u64,
    pub public_key: Vec<u8>,
}

impl Account {
    pub fn new(address: String) -> Self {
        Self {
            address,
            balance: 0,
            nonce: 0,
            public_key: Vec::new(),
        }
    }
}