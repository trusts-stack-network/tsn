//! SLH-DSA (SPHINCS+) Implementation - Stateless Hash-Based Digital Signature Standard
//! 
//! Basé sur NIST FIPS 205 - Security Levels 1, 3, et 5

use sha3::{Shake128, Shake256, Sha3_256, Sha3_512, Digest, digest::{Update, ExtendableOutput, XofReader}};
use rand::{CryptoRng, RngCore};
use thiserror::Error;
use zeroize::{Zeroize, ZeroizeOnDrop};

/// Paramètres de sécurité SLH-DSA
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParameterSet {
    /// SLH-DSA-SHA2-128s (small signatures)
    Sha2_128s,
    /// SLH-DSA-SHA2-128f (fast)
    Sha2_128f,
    /// SLH-DSA-SHA2-192s
    Sha2_192s,
    /// SLH-DSA-SHA2-192f
    Sha2_192f,
    /// SLH-DSA-SHA2-256s
    Sha2_256s,
    /// SLH-DSA-SHA2-256f
    Sha2_256f,
    /// SLH-DSA-SHAKE-128s
    Shake128s,
    /// SLH-DSA-SHAKE-128f
    Shake128f,
    /// SLH-DSA-SHAKE-192s
    Shake192s,
    /// SLH-DSA-SHAKE-192f
    Shake192f,
    /// SLH-DSA-SHAKE-256s
    Shake256s,
    /// SLH-DSA-SHAKE-256f
    Shake256f,
}

impl ParameterSet {
    /// Retourne n (taille de sécurité en octets)
    pub const fn n(&self) -> usize {
        match self {
            Self::Sha2_128s | Self::Sha2_128f | Self::Shake128s | Self::Shake128f => 16,
            Self::Sha2_192s | Self::Sha2_192f | Self::Shake192s | Self::Shake192f => 24,
            Self::Sha2_256s | Self::Sha2_256f | Self::Shake256s | Self::Shake256f => 32,
        }
    }

    /// Hauteur totale de l'hypertree
    pub const fn h(&self) -> usize {
        match self {
            Self::Sha2_128s | Self::Sha2_192s | Self::Sha2_256s |
            Self::Shake128s | Self::Shake192s | Self::Shake256s => 63,
            Self::Sha2_128f | Self::Sha2_192f | Self::Sha2_256f |
            Self::Shake128f | Self::Shake192f | Self::Shake256f => 66,
        }
    }

    /// Nombre de couches dans l'hypertree
    pub const fn d(&self) -> usize {
        match self {
            Self::Sha2_128s | Self::Sha2_192s | Self::Sha2_256s |
            Self::Shake128s | Self::Shake192s | Self::Shake256s => 7,
            Self::Sha2_128f | Self::Sha2_192f | Self::Sha2_256f |
            Self::Shake128f | Self::Shake192f | Self::Shake256f => 22,
        }
    }

    /// Paramètre Winternitz
    pub const fn w(&self) -> usize { 16 }

