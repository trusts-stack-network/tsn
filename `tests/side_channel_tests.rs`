use tsn_crypto::poseidon::PoseidonHash;
use std::collections::HashMap;
use cache_size::CacheSize;

#[test]
fn test_poseidon_cache_timing() {
    // Test de cache timing sur Poseidon
    let hasher = PoseidonHash::new();
    let cache_sizes = CacheSize::detect();
    
    // Créer des inputs qui ciblent différents niveaux de cache
    let inputs = generate_cache_targeting_inputs(cache_sizes);
    
    let mut timing_map: HashMap<usize, Vec<u64>> = HashMap::new();
    
    for (cache_level, input) in inputs {
        let start = rdtsc(); // Read Time-Stamp Counter
        let _hash = hasher.hash(&input);
        let end = rdtsc();
        
        timing_map.entry(cache_level).or_default().push(end - start);
    }
    
    // Analyser les patterns de timing
    for (level, times) in timing_map {
        let avg_time = times.iter().sum::<u64>() / times.len() as u64;
        let variance = calculate_variance(&times, avg_time);
        
        // Variance élevée indique possible side-channel
        assert!(
            variance < 1000, // Seuil arbitraire, à calibrer
            "High timing variance detected for cache level {}: {}", 
            level, variance
        );
    }
}

fn generate_cache_targeting_inputs(cache: CacheSize) -> Vec<(usize, [u8; 64])> {
    // Génère des inputs conçus pour cibler L1/L2/L3
    vec![
        (1, generate_l1_input(cache.l1())),
        (2, generate_l2_input(cache.l2())),
        (3, generate_l3_input(cache.l3())),
    ]
}