use tsn_crypto::signature::{SignatureScheme, verify_signature};
use std::time::{Instant, Duration};
use rand::Rng;

#[test]
fn test_signature_verification_timing_attack() {
    // Test de timing attack sur la vérification de signature
    let message = b"test message";
    let valid_sig = /* générer signature valide */;
    let invalid_sig = /* générer signature invalide */;
    
    // Mesurer le temps de vérification
    let valid_time = measure_verification_time(&valid_sig, message);
    let invalid_time = measure_verification_time(&invalid_sig, message);
    
    // Si les temps sont significativement différents, vulnérabilité
    let time_diff = (valid_time.as_nanos() as f64 - invalid_time.as_nanos() as f64).abs();
    let avg_time = ((valid_time + invalid_time) / 2).as_nanos() as f64;
    
    // Échec si différence > 5% (marge pour le bruit)
    assert!(
        (time_diff / avg_time) < 0.05,
        "Possible timing attack: verification time differs by {:.2}%", 
        (time_diff / avg_time) * 100.0
    );
}

fn measure_verification_time(sig: &[u8], message: &[u8]) -> Duration {
    let start = Instant::now();
    for _ in 0..1000 {
        let _ = verify_signature(sig, message);
    }
    start.elapsed()
}