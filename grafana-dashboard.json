{
  "dashboard": {
    "id": null,
    "title": "Trust Stack Network (TSN) - Node Monitoring",
    "tags": ["tsn", "blockchain", "p2p"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "5s",
    "schemaVersion": 27,
    "version": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Network Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "tsn_connected_peers",
            "legendFormat": "Connected Peers",
            "refId": "A"
          },
          {
            "expr": "tsn_network_hashrate_hashes_per_second",
            "legendFormat": "Hashrate (H/s)",
            "refId": "B"
          },
          {
            "expr": "rate(tsn_transactions_processed_total[5m])",
            "legendFormat": "TPS",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "displayMode": "list",
              "orientation": "horizontal"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            },
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Node Health Status",
        "type": "stat",
        "targets": [
          {
            "expr": "tsn_node_uptime_seconds",
            "legendFormat": "Uptime",
            "refId": "A"
          },
          {
            "expr": "tsn_block_sync_lag",
            "legendFormat": "Sync Lag (blocks)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "custom": {
              "displayMode": "list",
              "orientation": "horizontal"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 60
                },
                {
                  "color": "green",
                  "value": 300
                }
              ]
            },
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Transaction Processing Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(tsn_transactions_processed_total[1m])",
            "legendFormat": "Transactions/sec",
            "refId": "A"
          },
          {
            "expr": "rate(tsn_transactions_received_total[1m])",
            "legendFormat": "Received/sec",
            "refId": "B"
          },
          {
            "expr": "rate(tsn_transactions_rejected_total[1m])",
            "legendFormat": "Rejected/sec",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Transactions per second",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Network Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "tsn_network_latency_ms",
            "legendFormat": "Average Latency",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(tsn_network_latency_histogram_bucket[5m]))",
            "legendFormat": "95th Percentile",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(tsn_network_latency_histogram_bucket[5m]))",
            "legendFormat": "99th Percentile",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Latency (ms)",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Peer Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "tsn_connected_peers",
            "legendFormat": "Connected Peers",
            "refId": "A"
          },
          {
            "expr": "rate(tsn_peer_connections_total[5m])",
            "legendFormat": "New Connections/min",
            "refId": "B"
          },
          {
            "expr": "rate(tsn_peer_disconnections_total[5m])",
            "legendFormat": "Disconnections/min",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Count",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 17
        }
      },
      {
        "id": 6,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "tsn_memory_usage_bytes / 1024 / 1024",
            "legendFormat": "Memory Usage (MB)",
            "refId": "A"
          },
          {
            "expr": "tsn_mempool_size_bytes / 1024 / 1024",
            "legendFormat": "Mempool Size (MB)",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Memory (MB)",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 17
        }
      },
      {
        "id": 7,
        "title": "Block Processing",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(tsn_blocks_processed_total[5m])",
            "legendFormat": "Blocks Processed/min",
            "refId": "A"
          },
          {
            "expr": "rate(tsn_blocks_received_total[5m])",
            "legendFormat": "Blocks Received/min",
            "refId": "B"
          },
          {
            "expr": "rate(tsn_blocks_rejected_total[5m])",
            "legendFormat": "Blocks Rejected/min",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Blocks per minute",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 26
        }
      },
      {
        "id": 8,
        "title": "Network Errors",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(tsn_network_errors_total[5m])",
            "legendFormat": "Network Errors/min",
            "refId": "A"
          },
          {
            "expr": "rate(tsn_protocol_errors_total[5m])",
            "legendFormat": "Protocol Errors/min",
            "refId": "B"
          },
          {
            "expr": "rate(tsn_rate_limit_hits_total[5m])",
            "legendFormat": "Rate Limit Hits/min",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Errors per minute",
            "min": 0
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 26
        }
      },
      {
        "id": 9,
        "title": "Hashrate Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "tsn_network_hashrate_hashes_per_second",
            "legendFormat": "Network Hashrate",
            "refId": "A"
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 35
        }
      },
      {
        "id": 10,
        "title": "Sync Status",
        "type": "stat",
        "targets": [
          {
            "expr": "tsn_block_height",
            "legendFormat": "Current Block Height",
            "refId": "A"
          },
          {
            "expr": "tsn_block_sync_lag",
            "legendFormat": "Sync Lag (blocks)",
            "refId": "B"
          },
          {
            "expr": "rate(tsn_block_height[5m]) * 60",
            "legendFormat": "Blocks/min",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "custom": {
              "displayMode": "list",
              "orientation": "horizontal"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 10
                }
              ]
            },
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 35
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(tsn_connected_peers, instance)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Node Events",
          "datasource": "prometheus",
          "expr": "changes(tsn_node_uptime_seconds[1m]) > 0",
          "titleFormat": "Node Restart",
          "textFormat": "Node restarted at {{$value}}"
        }
      ]
    }
  }
}