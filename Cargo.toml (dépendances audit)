[dependencies]
subtle = "2.5"
zeroize = { version = "1.7", features = ["derive"] }
rand = { version = "0.8", features = ["getrandom"] }
aes-gcm = "0.10"
chacha20poly1305 = "0.10"
sha2 = "0.10"
hmac = "0.12"
argon2 = "0.5"

[dev-dependencies]
proptest = "1.4"
criterion = { version = "0.5", features = ["html_reports"] }
libfuzzer-sys = "0.4"
dudect-bencher = "0.10"  # Pour tests DoC (Distinguishing attacks)

[[bench]]
name = "timing_bench"
harness = false

[[bin]]
name = "fuzz_target_decrypt"
path = "fuzz/fuzz_targets/decrypt.rs"
test = false
doc = false